# ── Copy this to .env and fill in your values ───────────────────────────────
# NEVER commit .env to git. It's already listed in .gitignore.

# Required: FREE Groq API key — get one at https://console.groq.com (no credit card)
GROQ_API_KEY=gsk_...

# Optional: which Groq model to use
# llama-3.3-70b-versatile = smartest (default)
# llama-3.1-8b-instant    = fastest
GROQ_MODEL=llama-3.3-70b-versatile

# TTS backend: "termux" (free, default) or "elevenlabs" (paid, richer voice)
TTS_BACKEND=termux

# ElevenLabs — only needed if TTS_BACKEND=elevenlabs
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=EXAVITQu4vr4xnSDxMaL

# Phrase to pause the agent (say it out loud)
SLEEP_PHRASE=go to sleep
WAKE_PHRASE=hey buddy

# How many recent conversation turns to keep in context
CONTEXT_WINDOW_TURNS=10

# Database file (relative to voice_agent/ directory)
DB_PATH=memory.db

# Phase 3 — Telegram (leave blank for now)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
